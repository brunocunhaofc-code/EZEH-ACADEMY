# GEMINI_API_KEYS: Claves para rotación (opcional hasta 3 o más)
GEMINI_API_KEY1="tu_clave_1"
GEMINI_API_KEY2="tu_clave_2"
GEMINI_API_KEY3="tu_clave_3"

# APP_URL: La URL donde se aloja esta aplicación.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
